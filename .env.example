# Copy to .env and fill in. NEVER commit .env.
NODE_ENV=development
PORT=3000

# 32-byte key, base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Losing this key makes encrypted bank numbers and KYC files UNRECOVERABLE.
APP_ENC_KEY=

DB_FILE=./data/yumm-hr.db
KYC_DIR=./data/kyc

# First-run only: creates the initial admin on startup IF no users exist yet.
# Set these on a fresh deploy, log in, then DELETE them from the environment.
# BOOTSTRAP_ADMIN_USER=karun
# BOOTSTRAP_ADMIN_PASSWORD=ChangeMe#Strong2026
